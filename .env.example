APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# 公网 HTTPS 必须与浏览器一致，否则 Filament/Livewire 脚本混合内容被拦、登录 405（见 docs/admin-filament-first-deploy.md）
# APP_URL=https://你的域名

# 部署说明：composer / php artisan / Filament 安装与升级请在「服务器」或 Docker php 容器内执行（见 docs/admin-filament-rebuild-plan.md「零、环境与职责」、scripts/server-update.sh）。本地无 PHP 时可只改代码、推 Git，由服务器拉取后装依赖。

# 独立后台域名（可选）：与前台拆 Host 时需同时设置 APP_FRONT_DOMAIN；留空则后台仍为 /admin 路径
# Docker 示例见 docker/nginx/conf.d/admin.conf（admin.localhost）
# ADMIN_DOMAIN=admin.localhost
# APP_FRONT_DOMAIN=localhost
# SESSION_DOMAIN=.localhost
# SESSION_SAME_SITE=lax

LOG_CHANNEL=stack
# stack 默认写入 stderr + storage/logs；任一通道异常不阻断业务（见 config/logging.php）
# 仅需容器日志时可设：LOG_CHANNEL=stderr
# LOG_STACK_CHANNELS=stderr,single
# LOG_STACK_IGNORE_EXCEPTIONS=true
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
# 本机可 file；Docker（尤其 Windows 挂载）建议 redis，见 docker-compose 中 redis 服务
# 本地 Docker（Windows 挂载）建议 redis，需 PHP redis 扩展 + REDIS_*；纯本机可 file
SESSION_DRIVER=file
SESSION_LIFETIME=120
# HTTP / 纯 IP 访问时不要设为 true，否则浏览器不发送 Cookie，登录易 419（CSRF/会话失效）
# SESSION_SECURE_COOKIE=false
# Filament 后台左上角品牌文案（完整字符串；不设置则用「APP_NAME + 后台」）
# FILAMENT_BRAND_NAME="OpenClaw 智信 后台"
# 后台独立 Session Cookie，与前台分离，避免一处登出牵连另一处；需与 SESSION_COOKIE 不同
# FILAMENT_SESSION_COOKIE=oc_filament_session

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
# 超时（秒），避免 SMTP 长时间阻塞请求；QQ 示例见下
MAIL_TIMEOUT=30
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# —— QQ 邮箱 SMTP 示例（授权码非登录密码；勿将真实授权码提交到 Git）——
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.qq.com
# MAIL_PORT=465
# MAIL_USERNAME=你的QQ邮箱@qq.com
# MAIL_PASSWORD=SMTP授权码
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS=你的QQ邮箱@qq.com
# MAIL_FROM_NAME="OpenClaw 智信"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# 浏览器实际访问的 host:port 需在此列表中，Sanctum 才会为 /api/admin/* 启用 Session + CSRF Cookie
# 示例：本机 Docker 映射 8083 时加入 localhost:8083
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8083,127.0.0.1,127.0.0.1:8083
# 若配置了 APP_FRONT_DOMAIN / ADMIN_DOMAIN，sanctum.php 会自动附加到 stateful 域名列表

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# 演示支付（模拟成功并写 orders + 会员）；生产务必 false
PAYMENT_SIMULATE=true

# 静态资源：false 用 ASSET_VERSION 拼 ?v=，避免 Docker 挂载卷上 filemtime 拖慢整页
PUBLIC_ASSET_FILEMTIME=false
ASSET_VERSION=1

# 微信小程序（服务端 jscode2session；AppSecret 勿写入小程序前端）
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
# 订阅消息：公众平台「订阅消息 → 我的模板」模板 ID；逗号分隔，供小程序 requestSubscribeMessage（最多 3 个）
# 若留空，接口会读 Filament「站点设置 → 微信小程序订阅消息模板 ID」（site_settings）
WECHAT_MINI_SUBSCRIBE_TEMPLATE_IDS=
# 可选：会员到期提醒单独指定 send 用模板；留空则用上一行第一个 ID
WECHAT_MINI_SUBSCRIBE_MEMBERSHIP_EXPIRY_TEMPLATE_ID=
# 可选：JSON，键为模板 keyword（thing1/time2/number3），值为 member_name|expires_at|days_left|rights_hint（与模板不一致会 47003）
# WECHAT_MINI_SUBSCRIBE_EXPIRY_FIELD_MAP={"thing1":"member_name","time2":"expires_at","number3":"days_left","thing4":"rights_hint"}
WECHAT_MINI_SUBSCRIBE_JUMP_PAGE=pages/vip/vip
WECHAT_MINI_SUBSCRIBE_MINIPROGRAM_STATE=formal
WECHAT_MINI_SUBSCRIBE_EXPIRY_DAYS_BEFORE=3

# 企业微信自建应用（OAuth 绑定 + 应用消息推送，见 config/wecom.php）
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
# 与企微后台「网页授权回调域名」一致时的完整回调 URL（可选，默认使用 APP_URL + /wecom/oauth/callback）
WECOM_OAUTH_REDIRECT_URI=

# SBTI：无登录管理后台密钥（访问 /personality-quiz/manage?token=... 与 API Header）
PERSONALITY_QUIZ_ADMIN_TOKEN=
